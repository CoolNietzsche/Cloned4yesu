---
// Fixed header bar: logo + Apply CTA + light/dark toggle + menu trigger.
// Faithful to the template's markup/classes so the theme CSS styles it 1:1.
---
<header id="header" class="mxd-header">
  <div class="mxd-header__logo loading-fade">
    <a class="mxd-logo" href="/">
      <img alt="StartupET" class="mxd-logo__image" height="61" width="160" src="/img/startupet/logo-transparent.png" />
      <div class="mxd-logo__text">
        <span class="mxd-scramble">StartupET</span><span class="mxd-scramble">Ethiopia</span>
      </div>
    </a>
  </div>
  <div class="mxd-header__controls loading-fade">
    <a class="btn mxd-header__link slide-right" aria-label="Apply for Designation" href="#journey" data-cursor-text="Apply">
      <span class="btn-caption"><span class="mxd-scramble">Apply for Designation</span></span>
      <i><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 18"><path d="M3.1,15.6h2.4v2.4h-2.4v-2.4ZM10.2,18h2.4v-2.4h-2.4v2.4ZM14.9,4.7H5.5V0H.8v2.4h2.4v11.8h9.4v-2.4h-7.1v-4.7h9.4v2.4h2.4v-4.7h-2.4ZM12.5,11.8h2.4v-2.4h-2.4v2.4Z"></path></svg></i>
    </a>
    <button id="color-switcher" class="btn mxd-color-switcher" type="button" role="switch" aria-label="light/dark mode" aria-checked="false">
      <span class="switcher-text">Night</span>
      <span class="switcher-icon night"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18"><path d="M7.7,0h7.7v2.6h-2.6v2.6h-2.6v7.7h2.6v2.6h2.6v2.6h-7.7v-2.6h-2.6v-2.6h-2.6v-7.7h2.6v-2.6h2.6V0Z"></path></svg></span>
    </button>
  </div>
</header>
<div class="mxd-menu__contain loading-fade">
  <div class="mxd-menu__toggle">
    <a href="#0" class="mxd-menu__hamburger" aria-label="Menu">
      <div class="hamburger__line"></div><div class="hamburger__line"></div>
    </a>
  </div>
</div>
