---
// Final CTA band (spec section 19).
---
<div class="mxd-section padding-pre-title">
  <div class="mxd-container grid-l-container">
    <div class="mxd-block">
      <div class="final-cta" data-el-anim="inUp">
        <h2 class="final-cta__title reveal-type" data-anim="revealType">Ready to Register Your Startup?</h2>
        <p class="final-cta__body t-large">Apply for official Startup Designation and unlock tax relief, credit guarantees, procurement access, and regional support through the StartupET platform.</p>
        <div class="final-cta__actions">
          <a class="btn btn-anim btn-default" href="#journey" data-cursor-text="Apply">
            <span class="btn-caption"><span class="mxd-scramble">Apply for Designation</span></span>
          </a>
          <a class="btn btn-line btn-line-default" href="#contact" data-cursor-text="Contact">
            <span class="btn-caption mxd-scramble">Contact MinT</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
