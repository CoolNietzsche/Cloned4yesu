---
// Footer — branded, institutional (no invented socials/contacts).
const year = new Date().getFullYear();
---
<footer class="mxd-footer blur-section">
  <div class="mxd-container grid-l-container">
    <div class="mxd-block">
      <div class="container-fluid p-0">
        <div class="row g-0 mxd-grid-gap mxd-footer__top">
          <div class="col-12 col-xl-7 mxd-grid-item">
            <p class="footer-headline mxd-split-lines" data-anim="splitLines">Ethiopia's startup era has begun. Register, apply for Designation, and access national incentives.</p>
          </div>
          <div class="col-12 col-xl-5 mxd-grid-item">
            <div class="footer-cta" data-el-anim="inUp">
              <a class="btn btn-anim btn-default btn-mobile-sled" href="#journey" data-cursor-text="Apply">
                <span class="btn-caption"><span class="mxd-scramble">Apply for Designation</span></span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="mxd-block">
      <div class="container-fluid p-0">
        <div class="row g-0 mxd-footer__bottom">
          <div class="col-12 col-xl-6 mxd-grid-item">
            <p class="footer-data"><span>Federal Democratic Republic of Ethiopia. All rights reserved</span></p>
          </div>
          <div class="col-12 col-xl-6 mxd-grid-item">
            <p class="footer-data justify-end"><span>A national platform by&nbsp;<a href="#0"><span class="mxd-scramble">Ministry of Innovation and Technology</span></a></span></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
