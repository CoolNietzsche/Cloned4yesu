---
// About / Mission & Vision (spec section 3) — section-manifest with a large
// scroll-revealed statement, plus a mission/vision two-up below.
---
<div id="about" class="blur-section mxd-section padding-top-subtitle">
  <div class="mxd-container grid-l-container">
    <div class="mxd-block">
      <div class="mxd-section-manifest pre-list">
        <div class="container-fluid p-0">
          <div class="row g-0">
            <div class="col-12 mxd-grid-item">
              <div class="mxd-section-manifest__wrap wrap-text-s">
                <div class="mxd-section-manifest__controls" data-el-anim="inUp">
                  <a class="btn btn-line btn-line-default" href="#journey" data-cursor-text="Start">
                    <span class="btn-caption mxd-scramble">About StartupET</span>
                  </a>
                </div>
                <div class="mxd-section-manifest__text manifest-text-m">
                  <span class="manifest manifest-m mxd-split-lines" data-anim="splitLines">A single national registry, replacing fragmented regional processes. One transparent system to register, monitor, and report on national STI activity across every region of Ethiopia.</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mxd-block">
      <div class="container-fluid p-0">
        <div class="row g-0 mxd-grid-gap">
          <div class="col-12 col-xl-6 mxd-grid-item">
            <div class="mxd-mission-card" data-el-anim="inUp">
              <span class="tag tag-s mxd-scramble">Mission</span>
              <p class="t-large">Give founders, regional hub administrators, and evaluators a single, transparent system to register, monitor, and report on national STI activity — replacing legacy, disconnected regional pipelines.</p>
            </div>
          </div>
          <div class="col-12 col-xl-6 mxd-grid-item">
            <div class="mxd-mission-card" data-el-anim="inUp">
              <span class="tag tag-s mxd-scramble">Vision</span>
              <p class="t-large">To be the authoritative national record of Ethiopia's registered startups and innovation hubs — built for transparency, public accountability, and consistent application of the Startup Proclamation.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
