import Thresholds from '../components/Thresholds.astro';
import AltTrack from '../components/AltTrack.astro';
import Journey from '../components/Journey.astro';
import Governance from '../components/Governance.astro';
import Incentives from '../components/Incentives.astro';
import Sandbox from '../components/Sandbox.astro';
import Compliance from '../components/Compliance.astro';
import RegionalMap from '../components/RegionalMap.astro';
import DataProtection from '../components/DataProtection.astro';
